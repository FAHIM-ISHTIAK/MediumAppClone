DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-1-ap-south-1.pooler.supabase.com:5432/postgres
# Use auto/session for long-lived servers like Render. Only force transaction for serverless bursts.
DATABASE_CONNECTION_MODE=auto
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_JWT_SECRET=YOUR_SUPABASE_JWT_SECRET
FRONTEND_URL=http://localhost:5173,http://localhost:3000
